# ── Required: LiveKit Cloud ──
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Required: LLM + STT ──
GROQ_API_KEY=

# ── Required: TTS ──
DEEPGRAM_API_KEY=

# ── Required: UI Access Password ──
JARVIS_UI_PASSWORD=

# ── Optional: Model overrides ──
GROQ_LLM_MODEL=llama-3.3-70b-versatile
DEEPGRAM_STT_MODEL=nova-2
DEEPGRAM_TTS_MODEL=aura-2-neptune-en
TTS_SAMPLE_RATE=24000

# ── Optional: Tool integrations ──
GOOGLE_CLOUD_API_KEY=    # Enables YouTube search + Google Fact Check tools
TAVILY_API_KEY=          # Enables Tavily search (primary); falls back to DDG+BS4 if not set
SENDGRID_API_KEY=        # Enables email dispatch tool
JARVIS_EMAIL_IDENTITY=   # Sender address for email tool (e.g. jarvis@yourdomain.com)
GEMINI_API_KEY=          # LLM fallback (used if Groq 429s)
