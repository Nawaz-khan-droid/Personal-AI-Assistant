GROQ_API_KEY="your_groq_api_key_here"
GROQ_MODEL="openai/gpt-oss-120b"
ELEVENLABS_API_KEY="your_elevenlabs_api_key_here"
ELEVENLABS_STT_MODEL="scribe_v2"
GOOGLE_FACTCHECK_API_KEY="your_google_factcheck_api_key_here"
NEWSDATA_API_KEY="your_newsdata_api_key_here"
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-2.0-flash-exp"
GEMINI_MODEL_FALLBACKS="gemini-flash-latest,gemini-2.5-flash"
GEMINI_TIMEOUT_SECONDS="30"
GEMINI_MAX_RETRIES="1"
LLM_PROVIDER="gemini"

# ElevenLabs configuration (TTS)
# ELEVENLABS_VOICE_ID selects the voice used for TTS. Default is a server-side safe fallback.
ELEVENLABS_VOICE_ID="your_voice_id_here"  # optional: replace with your preferred voice id

# ELEVENLABS_AGENT_ID is optional and NOT required for TTS. Leave blank unless you explicitly enable agent usage.
ELEVENLABS_AGENT_ID=""  # optional: conversational agent id (future use)
# To enable agent-based flows (ADVANCED), set ELEVENLABS_ENABLE_AGENT=true in your .env and implement secure server-side logic.
ELEVENLABS_ENABLE_AGENT="false"

# ─────────────────────────────────────────────────────
# LiveKit (Production-Grade WebRTC Pipeline)
# ─────────────────────────────────────────────────────
# Local dev defaults (set by livekit-server.exe --dev)
LIVEKIT_URL="ws://localhost:7880"
LIVEKIT_API_KEY="devkey"
LIVEKIT_API_SECRET="secret"
# For production cloud VPS, replace with your actual LiveKit Server URL and keys
